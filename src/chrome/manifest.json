{
  "manifest_version": 3,
  "name": "__MSG_wasavi_name__",
  "short_name": "__MSG_wasavi_name__",
  "version": "2026.6.23",
  "description": "__MSG_wasavi_desc__",
  "default_locale": "en_US",
  "icons": {
     "16": "images/icon016.png",
     "48": "images/icon048.png",
    "128": "images/icon128.png"
  },
  "permissions": [
    "tabs", "clipboardRead", "clipboardWrite", "contextMenus",
    "storage"
  ],
  "host_permissions": [
    "https://*.dropboxapi.com/*",
    "https://*.google.com/*", "https://*.googleapis.com/*", "https://*.googleusercontent.com/*",
    "https://apis.live.net/*"
  ],
  "background": {
    "service_worker": "backend/sw.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "exclude_matches": [
        "http://wasavi.appsweets.net/*",
        "https://wasavi.appsweets.net/*"
      ],
      "js": [
        "frontend/extension_wrapper.js",
        "frontend/agent.js"
      ],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "wasavi.html",
        "scripts/page_context.js",
        "frontend/vimwasm_frame.js",
        "frontend/extension_wrapper.js",
        "frontend/vim-wasm/vimwasm.js",
        "frontend/vim-wasm/vim.js",
        "frontend/vim-wasm/vim.wasm",
        "frontend/vim-wasm/vim.data",
        "frontend/colors/vividchalk.vim",
        "frontend/colors/brogrammer.vim",
        "frontend/colors/birds-of-paradise.vim"
      ],
      "matches": [
        "http://*/*",
        "https://*/*"
      ]
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "homepage_url": "http://appsweets.net/"
}
